0)call SetUnitLifePercentBJ(udg_DuelNomerHero[udg_NomeVizovIgroka],100)call SetUnitManaPercentBJ(udg_DuelNomerHero[udg_IgrokdueliDa],100)call SetUnitManaPercentBJ(udg_DuelNomerHero[udg_NomeVizovIgroka],100)call SetUnitInvulnerable(udg_DuelNomerHero[udg_NomeVizovIgroka],false)call SetUnitInvulnerable(udg_DuelNomerHero[udg_IgrokdueliDa],false)call PauseUnitBJ(true,udg_DuelNomerHero[udg_IgrokdueliDa])call PauseUnitBJ(true,udg_DuelNomerHero[udg_NomeVizovIgroka])call PolledWait(1.00)call DisplayTextToForce(GetForceOfPlayer(udg_VizovDueliIgrok),"3!!!")call DisplayTextToForce(GetForceOfPlayer(udg_IgrokDliadueli[udg_IgrokdueliDa]),"3!!!")call PolledWait(1.00)call DisplayTextToForce(GetForceOfPlayer(udg_VizovDueliIgrok),"2!!!")call DisplayTextToForce(GetForceOfPlayer(udg_IgrokDliadueli[udg_IgrokdueliDa]),"2!!!")call PolledWait(1.00)call DisplayTextToForce(GetForceOfPlayer(udg_VizovDueliIgrok),"1!!!")call DisplayTextToForce(GetForceOfPlayer(udg_IgrokDliadueli[udg_IgrokdueliDa]),"1!!!")call PolledWait(1.00)call SetUnitPositionLocFacingBJ(udg_DuelNomerHero[udg_NomeVizovIgroka],GetRectCenter(gg_rct_Duel1),0.00)call SetUnitPositionLocFacingBJ(udg_DuelNomerHero[udg_IgrokdueliDa],GetRectCenter(gg_rct_Duel2),180.00)call PauseUnitBJ(false,udg_DuelNomerHero[udg_IgrokdueliDa])call PauseUnitBJ(false,udg_DuelNomerHero[udg_NomeVizovIgroka])call SetUserControlForceOn(GetForceOfPlayer(udg_VizovDueliIgrok))call SetUserControlForceOn(GetForceOfPlayer(udg_IgrokDliadueli[udg_IgrokdueliDa]))call EnableOcclusionBJ(true,GetForceOfPlayer(udg_VizovDueliIgrok))call EnableOcclusionBJ(true,GetForceOfPlayer(udg_IgrokDliadueli[udg_IgrokdueliDa]))endfunctionfunction InitTrig_OkDuel1 takes nothing returns nothingset gg_trg_OkDuel1=CreateTrigger()call DisableTrigger(gg_trg_OkDuel1)call TriggerRegisterTimerEventPeriodic(gg_trg_OkDuel1,0.05)call TriggerAddAction(gg_trg_OkDuel1,function Trig_OkDuel1_Actions)endfunctionfunction Trig_VizovNowii1_Func005Func001C takes nothing retu