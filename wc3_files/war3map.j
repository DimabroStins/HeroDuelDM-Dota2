(Trig_VIBERI_MENIA_Func006C())thencall DialogAddButtonBJ(udg_DialogKomand,"|cffff0000Игра 3 на 3|r")set udg_ModKnopa[3]=GetLastCreatedButtonBJ()elseendifif(Trig_VIBERI_MENIA_Func007C())thencall DialogAddButtonBJ(udg_DialogKomand,"|cffff0000Игра 4 на 4|r")set udg_ModKnopa[4]=GetLastCreatedButtonBJ()elseendifcall DialogSetMessageBJ(udg_DialogKomand,"|cffff5500Возможные моды для игры:|r")call DialogDisplayBJ(true,udg_DialogKomand,Player(0))endfunctionfunction InitTrig_VIBERI_MENIA takes nothing returns nothingset gg_trg_VIBERI_MENIA=CreateTrigger()call TriggerRegisterTimerEventSingle(gg_trg_VIBERI_MENIA,0.00)call TriggerAddAction(gg_trg_VIBERI_MENIA,function Trig_VIBERI_MENIA_Actions)endfunctionfunction Trig_Neuspel_Func001C takes nothing returns booleanif(not(udg_Mod3vs3==0))thenreturn falseendifif(not(udg_Mod4vs4==0))thenreturn falseendifif(not(udg_ModFFL==0))thenreturn falseendifif(not(udg_ModStandart==0))thenreturn falseendifreturn trueendfunctionfunction Trig_Neuspel_Conditions takes nothing returns booleanif(not Trig_Neuspel_Func001C())thenreturn falseendifreturn trueendfunctionfunction Trig_Neuspel_Actions takes nothing returns nothingcall DisableTrigger(GetTriggeringTrigger())call DisableTrigger(gg_trg_ModFFL)call DisableTrigger(gg_trg_Mod4_vs_4)call DisableTrigger(gg_trg_Mod3_vs_3)call DisableTrigger(gg_trg_ModStandart)call EnableTrigger(gg_trg_lose2)call EnableTrigger(gg_trg_Win)set udg_ModStandart=1set udg_ModFFL=0set udg_Mod4vs4=0set udg_Mod3vs3=0call DisplayTimedTextToForce(GetPlayersAll(),10.00,"Красный игрок проспал и ничего невыбрал, значит играем на стандарте.")call DialogDisplayBJ(false,udg_DialogKomand,Player(0))call DialogClearBJ(udg_DialogKomand)set udg_POINTS_TO_WIN=2000endfunctionfunction InitTrig_Neuspel takes nothing returns nothingset gg_trg_Neuspel=CreateTrigger()call TriggerRegisterTimerEventSingle(gg_trg_Neuspel,10.00)call TriggerAddCondition(gg_trg_Neuspel,Condition(function Trig_N